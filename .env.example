# ==============================================================================
# Aria AI – Autonomous Real Estate Sales Agent Environment Variables
# ==============================================================================
# Rename this file to '.env' and fill in your actual credentials before running.
# Never commit your '.env' file to your public GitHub repository!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. n8n Configuration
# ------------------------------------------------------------------------------
# Secure webhook tunnel URL (e.g. via ngrok or cloudflare tunnel)
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
# Set this to your external tunnel URL so Telegram and Widget Webhooks can reach n8n
WEBHOOK_URL=https://your-n8n-tunnel.ngrok-free.dev

# ------------------------------------------------------------------------------
# 2. OpenRouter & AI Model Configuration
# ------------------------------------------------------------------------------
# Obtain your API key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default Model selections
AI_MODEL_QUALIFICATION=deepseek/deepseek-v4-flash
AI_MODEL_CONVERSATION=deepseek/deepseek-v4-flash
AI_MODEL_FOLLOWUP=deepseek/deepseek-v4-flash

# ------------------------------------------------------------------------------
# 3. Supabase Database Configuration
# ------------------------------------------------------------------------------
# Obtain credentials from your Supabase project dashboard (Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key_here

# Direct database connection string (for running SQL schema migrations)
# postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_db_password_here@db.your-project-id.supabase.co:5432/postgres

# ------------------------------------------------------------------------------
# 4. Telegram Bot Integration
# ------------------------------------------------------------------------------
# Create a bot via Telegram's BotFather and obtain the token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ_1234abcd

# Your personal Chat ID (to receive instant hot lead alerts and initial testing follow-ups)
# You can obtain this from Telegram bots like @userinfobot
TELEGRAM_MY_CHAT_ID=8195275061

# ------------------------------------------------------------------------------
# 5. Google Workspace Credentials (Calendar & Sheets)
# ------------------------------------------------------------------------------
# GCP Project OAuth2 Details (Used for n8n OAuth credential configuration)
GOOGLE_CLIENT_ID=your_gcp_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_gcp_client_secret_here

# Google Sheets Spreadsheet ID where CRM leads will sync
# Found in the URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheets_id_here

# Google Calendar Email address where property site visits are booked
GOOGLE_CALENDAR_EMAIL=your_calendar_email@gmail.com

# ------------------------------------------------------------------------------
# 6. Chat Widget Configuration
# ------------------------------------------------------------------------------
# Port for running the local website chat widget demo server
PORT=3000
