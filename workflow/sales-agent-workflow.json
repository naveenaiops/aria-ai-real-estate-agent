    {
      "parameters": {
        "jsCode": "let text = $input.first().json.output;\n\n// Remove markdown if AI added it\ntext = text.replace(/```json/g, \"\")\n           .replace(/```/g, \"\")\n           .trim();\n\nconst ai = JSON.parse(text);\n\nconst prev = $('Build Conversation Context').first().json;\n\n// Convert lead_data to object if it's stored as a string\nif (typeof prev.lead_data === 'string') {\n    prev.lead_data = JSON.parse(prev.lead_data);\n}\n\nreturn [{\n  json: {\n    reply: ai.reply,\n    lead_data: {\n      ...prev.lead_data,\n      ...ai.lead_data\n    },\n    ready_to_recommend: ai.ready_to_recommend,\n    sessionId: prev.sessionId,\n    history: prev.history,\n    message: prev.message,\n    isNewSession: prev.isNewSession\n  }\n}];"
      },
