    {
      "parameters": {
        "jsCode": "// Get webhook data\nconst webhook = $('Website Chat Lead Trigger').first().json.body;\n\n// Get session from Supabase\nconst rows = $input.all();\n\n// Existing session?\nconst session = rows.length > 0 &&\nrows[0].json.session_id ? rows[0].json : null;\n\n// Existing conversation history\nconst history = session?.history || \"\";\n\n// Existing lead data\nlet leadData = session?.lead_data || {};\n\nif (typeof leadData === \"string\") {\n    leadData = JSON.parse(leadData);\n}\n\nconsole.log(typeof leadData);\nconsole.log(leadData);\n\n// Build prompt for AI\nconst prompt = `Conversation so far:\n\n${history}\n\nLatest visitor message:\n\n${webhook.message}`;\n\nreturn [\n{\njson: {\nsessionId: webhook.sessionId,\nmessage: webhook.message,\nprompt,\nhistory,\nlead_data: leadData,\nisNewSession: session === null\n}\n}\n];"
      },
