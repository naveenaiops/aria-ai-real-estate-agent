    {
      "parameters": {
        "jsCode": "const leadData = $json.lead_data || {};\n\nfunction bareNumberToRupees(n) {\n    if (n >= 100000) return n;\n    if (n < 1000) {\n        return n >= 50 ? n * 100000 : n * 10000000;\n    }\n    return n;\n}\n\nfunction parseBudget(budget) {\n\n    if (!budget) return null;\n\n    if (typeof budget === \"number\") {\n        return bareNumberToRupees(budget);\n    }\n\n    let s = String(budget)\n        .toLowerCase()\n        .replace(/[,₹]/g, \"\")\n        .trim();\n\n    let m;\n\n    if ((m = s.match(/([0-9.]+)\\s*cr/))) {\n        return parseFloat(m[1]) * 10000000;\n    }\n\n    if ((m = s.match(/([0-9.]+)\\s*l/))) {\n        return parseFloat(m[1]) * 100000;\n    }\n\n    const n = parseFloat(s);\n\n    if (isNaN(n)) return null;\n\n    return bareNumberToRupees(n);\n\n}\n\nconst budget = parseBudget(leadData.budget);\n\nlet score = 0;\n\nif (leadData.phone) score += 10;\n\nif (leadData.email) score += 5;\n\nif (leadData.preferred_location) score += 10;\n\nif (budget !== null) {\n\n    if (budget >= 10000000)\n        score += 25;\n\n    else if (budget >= 7500000)\n        score += 20;\n\n    else\n        score += 10;\n\n}\n\nconst timeline = String(\n    leadData.purchase_timeline || \"\"\n).toLowerCase();\n\nif (timeline.includes(\"immediate\"))\n    score += 35;\n\nelse if (timeline.includes(\"3\"))\n    score += 25;\n\nelse if (timeline.includes(\"6\"))\n    score += 15;\n\nelse if (timeline.includes(\"exploring\"))\n    score += 5;\n\nscore = Math.min(score,100);\n\nlet status=\"COLD\";\n\nif(score>=80){\n\n    status=\"HOT\";\n\n}\nelse if(score>=50){\n\n    status=\"WARM\";\n\n}\n\nreturn [{\n    json:{\n        sessionId:$json.sessionId,\n\n        lead_data:leadData,\n\n        lead_score:score,\n\n        lead_status:status,\n\n        qualified:$json.ready_to_recommend,\n\n        reply:$json.reply\n    }\n}];"
      },
